{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/aria": [
      "default",
      {
        "aria-valid-attr-value": "off",
        "aria-required-parent": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "text-size-adjust",
          "text-wrap",
          "text-wrap: balance",
          "text-size-adjust: none",
          "backdrop-filter",
          "hyphens"
        ]
      }
    ]
  }
}